# Backend Express (apps/api) — variables de servidor. NUNCA commitear .env.local
PORT=4000
WEB_ORIGIN=http://localhost:3000
SUPABASE_URL=
# Llave SECRETA (bypassa RLS). Solo aquí, en el servidor. Nunca en el cliente.
SUPABASE_SECRET_KEY=
# Secreto de servicio compartido con el web app para autorizar POST /sellers/claim.
# Genera uno aleatorio y ponlo IDÉNTICO en apps/web/.env.local (CLAIM_SERVICE_TOKEN).
CLAIM_SERVICE_TOKEN=
# Stripe Connect — MODO PRUEBA. Pega aquí tu clave secreta de test (sk_test_...).
# NUNCA la de producción sin validar con contador (retenciones/CFDI). Solo en el backend.
STRIPE_SECRET_KEY=
# Signing secret del webhook de Stripe (whsec_...), para verificar firmas más adelante.
STRIPE_WEBHOOK_SECRET=
